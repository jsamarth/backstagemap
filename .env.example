# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server-side / cron)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cron protection (Vercel sets this automatically for cron invocations)
CRON_SECRET=

# Google Maps Places API (billing must be enabled in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Apify — https://apify.com (primary scraper; falls back to Firecrawl if not set or credits exhausted)
APIFY_API_KEY=

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=

# OpenAI — GPT-4o for AI parsing
OPENAI_API_KEY=

# Supabase Storage bucket name for raw scraped HTML (optional, defaults to html-scrapes)
# SCRAPE_STORAGE_BUCKET=html-scrapes
